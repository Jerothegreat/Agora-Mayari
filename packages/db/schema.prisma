generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UrgencyLevel {
  LOW
  MEDIUM
  HIGH
}

model SymptomReport {
  id           String       @id @default(cuid())
  createdAt    DateTime     @default(now())
  inputText    String
  age          Int?
  temperature  Float?
  durationDays Int?
  urgency      UrgencyLevel
  context      String
  recommendation Json
  symptomTags  Json
  aiResponse   Json
}

model VoiceSession {
  id            String   @id @default(uuid())
  channelName   String
  agentId       String?
  uid           String?
  status        String   @default("active")
  urgency       String?
  specialty     String?
  triageId      String?
  appointmentId String?
  transcript    Json     @default("[]")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("voice_sessions")
}
