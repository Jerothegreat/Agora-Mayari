# ── LLM ──────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

# ── LiveKit (https://cloud.livekit.io) ───────────────────────────────
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIw45vJxYcQW36
LIVEKIT_API_SECRET=your_livekit_api_secret

# ── STT — Deepgram (https://console.deepgram.com) ────────────────────
DEEPGRAM_API_KEY=your_deepgram_api_key

# ── TTS — pick one, leave the other blank ────────────────────────────
# Option A: Cartesia (https://cartesia.ai)
CARTESIA_API_KEY=your_cartesia_api_key

# Option B: Deepgram Aura (uses DEEPGRAM_API_KEY above, no extra key)
TTS_PROVIDER=cartesia

# ── Database ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require

# ── Auth ──────────────────────────────────────────────────────────────
ACCESS_TOKEN_SECRET=your_access_token_secret
REFRESH_TOKEN_SECRET=your_refresh_token_secret

# ── Server ────────────────────────────────────────────────────────────
PORT=3000
WEB_ORIGIN=http://localhost:5173

# ── Frontend (Next.js public vars) ───────────────────────────────────
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud
NEXT_PUBLIC_API_URL=http://localhost:3000
